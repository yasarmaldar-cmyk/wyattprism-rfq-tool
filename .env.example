# Copy this file to .env for local dev.
# In Streamlit Cloud, set these in the app's "Secrets" panel instead.

# Required — Claude API key for proposal generation
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Wyattprism Platform integration — only needed if you want the RFQ tool
# to push generated proposals back to the shell automatically.
SHELL_URL=https://wyattprism-platform.vercel.app
SHELL_CALLBACK_KEY=some-long-random-string-must-match-the-shell
