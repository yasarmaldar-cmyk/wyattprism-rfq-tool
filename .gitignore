# Secrets — never commit
.env
.env.*
!.env.example
.streamlit/secrets.toml

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/

# Virtual environments
.venv/
venv/
env/

# IDE / editor
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Project-specific: local history is generated by the tool; don't commit
# old client analyses to GitHub (sensitive client data).
history/*.json
!history/.gitkeep

# Streamlit
.streamlit/cache/
